# GitHub API — optional but increases rate limit from 60 to 5000 req/hour
# Create a token at: https://github.com/settings/tokens (no scope needed for public repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub username — used to fetch repos
NEXT_PUBLIC_GITHUB_USERNAME=your-github-username

# Formspree contact form endpoint
# Create a free form at https://formspree.io and paste the 8-char form ID here
NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxx

# EmailJS (alternative to Formspree — only fill if using EmailJS)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx

# Site URL (used for meta tags)
NEXT_PUBLIC_SITE_URL=https://yourportfolio.com
